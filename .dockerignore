# Dependencies — installed inside the image
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output — re-built inside the image (don't ship a stale local dist)
dist
build

# Local env files — never bake host env into the image. Coolify passes
# build-time vars via --build-arg (mapped to ARG/ENV in the Dockerfile).
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production.local

# IDE / editor / OS noise
.vscode
.vscode-test
.vscode-settings-recommendation.json
.idea
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# VCS — git history isn't needed at runtime
.git
.gitignore
.gitattributes

# Docker meta — don't recursively COPY them into the build context
docker-compose*
Dockerfile.dev
.dockerignore

# Docs / scripts — repo-only, not needed in image
README.md
*.md
docs/
create-test-credentials.sh
create-test-user.js
test-vehicle-api.sh
read

# Test / coverage
coverage/
.nyc_output
.jest

# Logs
logs
*.log

# Caches
.npm
.eslintcache
.cache
.parcel-cache
.next
.nuxt
.vuepress/dist
.serverless
.fusebox/
.dynamodb/
.tern-port

# Lockfile noise
*.tgz
.yarn-integrity
.node_repl_history

# Runtime PID files
pids
*.pid
*.seed
*.pid.lock
